# StealthHumanizer Environment Variables

# CLI/provider API keys
# Set whichever provider you want to use with `npm run cli -- humanize`.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
DEEPINFRA_API_KEY=
HUGGINGFACE_API_KEY=
CLOUDFLARE_API_KEY=
# Cloudflare API Key format: accountId:apiToken
# Example: a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6:your-api-token-here
# The accountId must be a 32-character hexadecimal string
ZAI_API_KEY=

# CLI Provider Paths (optional)
# Paths to CLI executables for claude-code and codex providers
STEALTHHUMANIZER_CLAUDE_CODE_BIN=
STEALTHHUMANIZER_CODEX_BIN=

# GPTZero API Key (optional)
# Used for AI detection scoring in the Detector tab
# Get your key at https://gptzero.me
GPTZERO_API_KEY=
